# 数据库连接字符串，格式为 mysql://user:password@host:port/database
DATABASE_URL="mysql://root:@localhost:3306/exam_system"

# 用于 JWT 签名的密钥，请使用一个强随机字符串
JWT_SECRET="your_super_secret_jwt_key_here"

# 应用 ID，如果不需要特定值，可以留空或使用默认值
VITE_APP_ID="exam_system_app"

# OAuth 服务器 URL，如果未使用 OAuth，可以留空
OAUTH_SERVER_URL=""

# 所有者 Open ID，如果不需要特定值，可以留空
OWNER_OPEN_ID=""

# Forge API URL 和 Key，如果未使用相关功能，可以留空
BUILT_IN_FORGE_API_URL=""
BUILT_IN_FORGE_API_KEY=""

# 运行环境，开发时设置为 development
NODE_ENV="development"
# 防止 URL 解析错误
VITE_OAUTH_PORTAL_URL="http://localhost:3000"
VITE_APP_ID="exam_system"
