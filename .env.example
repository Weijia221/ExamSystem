# ============================================================
# 在线考试系统 — 环境配置
# 克隆后首次运行：pnpm install && pnpm dev
# ============================================================

# 数据库连接（格式: mysql://user:password@host:port/database）
DATABASE_URL=mysql://root:@localhost:3306/exam_system

# JWT 密钥（开发环境用默认值即可，生产环境请更换）
JWT_SECRET=dev_secret_key_change_in_production

# OAuth 服务器 URL（留空使用本地开发账号：teacher/123456, student/123456, admin/123456）
OAUTH_SERVER_URL=

# 所有者 Open ID（留空自动使用 admin 角色）
OWNER_OPEN_ID=

# Forge API（本系统未使用，留空）
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# 运行环境：development（开发）/ production（生产）
NODE_ENV=development

# 端口
PORT=3000
